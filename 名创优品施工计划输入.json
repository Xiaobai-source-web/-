    "risks": [
      {
        "risk_name": "雨季影响地基与基础施工",
        "mitigation": "建立完善的现场排水系统，基坑周边设置截水沟和集水井；准备充足的防雨布覆盖裸露土体和钢筋；调整混凝土配合比，加强雨后基坑验槽。"
      },
      {
        "risk_name": "高温天气影响混凝土质量及人员效率",
        "mitigation": "避开中午高温时段进行露天作业，实行早晚班制；混凝土浇筑后及时覆盖薄膜并洒水养护，必要时添加缓凝剂；提供防暑降温饮料和药品。"
      },
      {
        "risk_name": "台风季节钢结构吊装安全风险",
        "mitigation": "密切关注气象预警，台风来临前停止高空吊装作业；对已安装的钢结构构件进行临时加固；检查塔吊和起重机的防风装置；制定应急撤离预案。"
      },
      {
        "risk_name": "钢结构构件供应延迟",
        "mitigation": "提前锁定钢厂货源，驻厂监造确保加工进度；合理安排运输批次，避免现场堆积或断供；预留一定的安装缓冲时间。"
      }
    ]
  }
